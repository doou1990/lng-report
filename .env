# LNG分析系统API配置
# 注意：以下为模拟值，实际使用时需要替换为真实的API密钥

# ======================
# 新闻搜索API
# ======================
# Tavily API密钥（模拟值 - 需要从 https://tavily.com 获取真实密钥）
TAVILY_API_KEY=tvly-demo-key-for-testing-only

# ======================
# 行业数据源API
# ======================
# ICIS API密钥（模拟值）
ICIS_API_KEY=icis_demo_key_12345

# GIE AGSI API密钥（模拟值）
GIE_API_KEY=gie_demo_key_12345

# EIA API密钥（模拟值）
EIA_API_KEY=eia_demo_key_12345

# ======================
# 文档管理API
# ======================
# Notion API密钥（模拟值）
NOTION_API_KEY=ntn_demo_key_12345

# ======================
# 系统配置
# ======================
# 数据更新频率（分钟）
UPDATE_INTERVAL=60

# 报告生成时间（24小时制）
REPORT_GENERATION_TIME=08:00

# 日志级别
LOG_LEVEL=info

# 数据存储路径
DATA_STORAGE_PATH=/root/.openclaw/workspace/memory/reports/LNG

# ======================
# 功能标志
# ======================
# 启用实时数据采集
ENABLE_REAL_TIME_DATA=true

# 启用自动报告生成
ENABLE_AUTO_REPORT=true

# 启用API健康监控
ENABLE_API_HEALTH_CHECK=true

# 启用数据质量检查
ENABLE_DATA_QUALITY_CHECK=true