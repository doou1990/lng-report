# LNG分析系统API配置示例文件
# 复制此文件为.env并填入实际的API密钥

# ======================
# 新闻搜索API
# ======================
# Tavily API密钥（从 https://tavily.com 获取）
TAVILY_API_KEY=tvly-your_actual_api_key_here

# ======================
# 行业数据源API
# ======================
# ICIS API密钥（国际价格数据）
ICIS_API_KEY=your_icis_api_key_here

# GIE AGSI API密钥（欧洲库存数据）
GIE_API_KEY=your_gie_api_key_here

# EIA API密钥（美国能源数据）
EIA_API_KEY=your_eia_api_key_here

# ======================
# 文档管理API
# ======================
# Notion API密钥（从 https://notion.so/my-integrations 获取）
NOTION_API_KEY=ntn_your_notion_api_key_here

# ======================
# 邮件通知API（可选）
# ======================
# Gmail账户（需要启用App Password）
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_RECIPIENT=recipient@example.com

# ======================
# 中国数据源API（可选）
# ======================
# 海关总署数据API
CUSTOMS_API_KEY=your_customs_api_key

# 国家统计局数据API
STATS_API_KEY=your_stats_api_key

# 行业数据平台API
OILCHEM_API_KEY=your_oilchem_api_key
SCI99_API_KEY=your_sci99_api_key

# ======================
# 系统配置
# ======================
# 数据更新频率（分钟）
UPDATE_INTERVAL=60

# 报告生成时间（24小时制）
REPORT_GENERATION_TIME=08:00

# 日志级别
LOG_LEVEL=info

# 数据存储路径
DATA_STORAGE_PATH=/root/.openclaw/workspace/memory/reports/LNG